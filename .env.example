# --- Meta WhatsApp Cloud API ---
WA_TOKEN=EAAxxxxxxxxxxxxxxxx              # access token from Meta developer dashboard
WA_PHONE_NUMBER_ID=1234567890123456      # phone number ID (not the actual number)
WA_VERIFY_TOKEN=sugarrush_verify         # any secret string — used once during webhook setup

# --- Firecrawl (search + web/menu scraping) ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Apify (Instagram public posts) ---
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxx
APIFY_IG_ACTOR=apify/instagram-post-scraper

# --- Google Places API (New) ---
GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (AI analysis) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- App config ---
DATABASE_URL=sqlite:///./scout.db
FRESHNESS_MINUTES=90
IG_POSTS_PER_PROFILE=8
MAX_NEW_COMPETITORS=3
